# Copy this file to ".env" and adjust as needed.
#
# VITE_FRONTEND_DOMAIN must match the FRONTEND_DOMAIN constant defined in
# admin/config/config.php. The admin panel uses it to build absolute image
# URLs (e.g. http://localhost:5173/uploads/products/xxx.jpg) when content
# is uploaded - this frontend variable exists so both sides always agree
# on the same domain and so the frontend code has a single source of
# truth for canonical/OG links.
VITE_FRONTEND_DOMAIN=http://localhost:5173
